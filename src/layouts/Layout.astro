---
import "../styles/globals.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Astro</title>
  </head>
  <!-- Preload background images to avoid flashing -->
  <link rel="preload" href="/assets/background_still.png" as="image" />
  <link rel="preload" href="/assets/background.gif" as="image" />
  <body>
    <header class="headerClass">
      <ul class="navBar">
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
      <!-- Move the button to the top-right -->
      <button id="backgroundButton" class="absolute top-4 right-4 px-6 py-2 bg-purple-600 text-white font-bold rounded hover:bg-purple-700">
        CLICK ME</button>
    </header>

    <main>
      <slot /> <!-- Page content goes here -->
    </main>

    <script>
        
      document.addEventListener("DOMContentLoaded", function () {
        const button = document.getElementById("backgroundButton");
        if (!button) return;

        const body = document.body;
        const originalBg = "url('/assets/background_still.png')";
        const gifBg = "url('/assets/background.gif')";

        body.style.backgroundImage = originalBg;

        button.addEventListener("click", () => {
          body.style.backgroundImage = gifBg;
          setTimeout(() => {
            body.style.backgroundImage = originalBg;
          }, 3000);
        });
      });
    </script>
  </body>
</html>
