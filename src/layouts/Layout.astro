---
import "../styles/globals.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Comic+Neue:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <title>Eising.net</title>
  </head>
  <!-- Preload animated background to minimize flashing -->
  <link rel="preload" href="/assets/background.gif" as="image" />
  <body>
    <header class="relative z-10 flex justify-center px-0 pb-0 pt-6 text-center">
      <div class="flex w-[min(95%,1200px)] flex-col border-[6px] border-double border-retro-gold bg-[linear-gradient(135deg,rgba(20,0,40,0.95),rgba(40,0,80,0.85))] pb-0 pt-4 shadow-neon">
        <div class="px-6 font-display tracking-[2px] text-retro-gold">
          <span class="block text-[1.35rem]">EISING.NET - THE OFFICIAL WEBSITE OF SHANE EISING</span>
          <span class="mt-1 block whitespace-pre text-[1.1rem] tracking-[1px] text-[#b8fffb]">Music    •    Theatre    •    Writing</span>
        </div>
        <ul class="header-tabs mt-4 list-none p-0">
          <li><a class="nav-tab" href="/"><span class="nav-tab-label">Home</span></a></li>
          <li><a class="nav-tab" href="/about"><span class="nav-tab-label">About</span></a></li>
          <li><a class="nav-tab" href="/portfolio"><span class="nav-tab-label">Portfolio</span></a></li>
          <li><a class="nav-tab" href="/contact"><span class="nav-tab-label">Contact</span></a></li>
        </ul>
      </div>
    </header>

    <main class="px-4">
      <slot />
    </main>

    <footer class="px-4 pb-12 pt-8 text-center font-mono text-sm text-retro-gold">
      <p class="my-1">© 1996 Shane Eising. All blinking lights reserved.</p>
      <p class="my-1">This website is best viewed with <span class="uppercase tracking-[0.1em] text-retro-cyan">Netscape Navigator</span></p>
    </footer>
  </body>
</html>
