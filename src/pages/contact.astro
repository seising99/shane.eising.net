---
import Layout from "../layouts/Layout.astro";

const contacts = [
  { label: "Email", href: "mailto:shane@eising.net", value: "shane@eising.net" },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/shane-eising/",
    value: "linkedin.com/in/shane-eising",
    external: true,
  },
  {
    label: "GitHub",
    href: "https://github.com/seising99",
    value: "github.com/seising99",
    external: true,
  },
];
---

<Layout>
  <section class="page-shell">
    <h1 class="page-title">-- Contact --</h1>
    <p class="mb-4 text-[1.05rem] leading-7">
      Want to chat about a project, compare notes on obscure musicals, or send over a mystery dinner prompt?
      Reach out through any of the links below and I'll get back as quickly as I can.
    </p>
    <ul class="mt-6 list-none p-0">
      {contacts.map(({ label, href, value, external }) => (
        <li class="mb-3">
          <span>{label}:</span>{" "}
          <a
            class="panel-link"
            href={href}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener" : undefined}
          >
            {value}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
