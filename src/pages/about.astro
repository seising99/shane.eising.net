---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="page-shell max-w-3xl border-[#2802fc] bg-[#9036c1]">
        <h1 class="page-title pb-4 text-white">-- About Me --</h1>
        <h2 class="pb-5 text-center font-display text-[16pt] text-white">
            Hello! You've reached Eising.net, the official website of Shane
            Eising: Musician, Writer, and Developer!
        </h2>
        <div class="space-y-4 p-1 text-left text-[14pt] text-white">
            <p>
                In addition to working as a full-time Software Engineer, I'm an
                aspiring composer / lyricist / playwright of musical theatre, as
                well as a composer for various video games, and a commissioned
                writer of murder-mystery dinners!
            </p>
            <p>
                I've also been known to write the occasional poem, and when
                distracted enough will compose music in other
                genres/forms/mediums. Check out the Portfolio page for a taste
                of all that!
            </p>
        </div>
    </section>
</Layout>
