---
import PortfolioFolder from "./PortfolioFolder.astro";
import type { Track } from "./music-player/types";

interface Project {
  title: string;
  description: string;
  longDescription: string;
  tracks: Track[];
}

interface FlattenedProject extends Project {
  categoryLabel?: string;
}

interface Category {
  label: string;
  projects: Project[];
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
const tabPositions = ["left", "center", "right"] as const;
const projects: FlattenedProject[] = categories.flatMap((category) =>
  category.projects.map((project, index) => ({
    ...project,
    categoryLabel: index === 0 ? category.label : undefined,
  })),
);
---

<div class="folder-stack mt-6" data-folder-root>
  {projects.map((project, index) => (
    <PortfolioFolder
      panelId={`portfolio-folder-panel-${index}`}
      tabPosition={tabPositions[index % tabPositions.length]}
      {...project}
    />
  ))}
</div>

<script>
  const panelAnimations = new WeakMap();
  const panelEase = "cubic-bezier(0.22, 1.2, 0.36, 1)";
  const getFolders = (root) => Array.from(root.querySelectorAll("[data-folder]"));

  const animatePanel = (panel, open) => {
    const existing = panelAnimations.get(panel);
    existing?.cancel();

    const computed = getComputedStyle(panel);
    const startHeight = panel.style.height === "auto" ? panel.scrollHeight : Number.parseFloat(computed.height) || 0;
    const startOpacity = Number.parseFloat(computed.opacity) || 0;

    if (open) {
      const targetHeight = panel.scrollHeight;
      panel.style.height = `${startHeight}px`;
      panel.style.opacity = `${startOpacity}`;
      panel.style.overflow = "hidden";

      const animation = panel.animate(
        [
          { height: `${startHeight}px`, opacity: startOpacity, transform: "translateY(-10px)" },
          { height: `${targetHeight + 14}px`, opacity: 1, transform: "translateY(0)" },
          { height: `${targetHeight}px`, opacity: 1, transform: "translateY(0)" },
        ],
        { duration: 380, easing: panelEase, fill: "forwards" },
      );

      panel.style.height = `${targetHeight}px`;
      panel.style.opacity = "1";

      animation.onfinish = () => {
        panel.style.height = "auto";
        panel.style.opacity = "";
        panel.style.overflow = "";
        panelAnimations.delete(panel);
      };

      animation.oncancel = () => {
        panelAnimations.delete(panel);
      };

      panelAnimations.set(panel, animation);
      return;
    }

    const animation = panel.animate(
      [
        { height: `${startHeight}px`, opacity: startOpacity, transform: "translateY(0)" },
        { height: "0px", opacity: 0, transform: "translateY(-10px)" },
      ],
      { duration: 220, easing: "ease-out", fill: "forwards" },
    );

    panel.style.height = "0px";
    panel.style.opacity = "0";
    panel.style.overflow = "hidden";

    animation.onfinish = () => {
      panel.style.height = "";
      panel.style.opacity = "";
      panel.style.overflow = "";
      panelAnimations.delete(panel);
    };

    animation.oncancel = () => {
      panelAnimations.delete(panel);
    };

    panelAnimations.set(panel, animation);
  };

  const setRootState = (root) => {
    root.toggleAttribute("data-has-open-folder", getFolders(root).some((item) => item.hasAttribute("data-open")));
  };

  const setOpen = (folder, open) => {
    const toggles = Array.from(folder.querySelectorAll("[data-folder-toggle]"));
    const panel = folder.querySelector(".folder-body");
    const view = folder.querySelector(".folder-view");
    const face = folder.querySelector(".folder-face");
    const root = folder.closest("[data-folder-root]");

    if (!(panel instanceof HTMLElement) || !(view instanceof HTMLElement) || !(face instanceof HTMLElement)) return;

    if (open) {
      folder.style.setProperty("--folder-open-height", `${face.offsetHeight + panel.scrollHeight}px`);
    } else {
      folder.style.removeProperty("--folder-open-height");
      for (const audio of folder.querySelectorAll("audio")) {
        if (audio instanceof HTMLAudioElement) {
          audio.pause();
        }
      }
    }

    folder.toggleAttribute("data-open", open);
    animatePanel(panel, open);

    for (const toggle of toggles) {
      toggle.setAttribute("aria-expanded", String(open));
    }

    if (root instanceof HTMLElement) {
      setRootState(root);
    }
  };

  for (const root of document.querySelectorAll("[data-folder-root]")) {
    const folders = getFolders(root);

    for (const folder of folders) {
      const toggles = Array.from(folder.querySelectorAll("[data-folder-toggle]"));
      const panel = folder.querySelector(".folder-body");
      const audio = panel?.querySelector("audio");

      if (panel instanceof HTMLElement && audio instanceof HTMLAudioElement) {
        audio.addEventListener("loadedmetadata", () => {
          const face = folder.querySelector(".folder-face");

          if (
            folder.hasAttribute("data-open") &&
            panel.style.height === "auto" &&
            face instanceof HTMLElement
          ) {
            folder.style.setProperty("--folder-open-height", `${face.offsetHeight + panel.scrollHeight}px`);
          }
        });
      }

      for (const toggle of toggles) {
        toggle.addEventListener("click", () => {
          for (const otherFolder of folders) {
            if (otherFolder !== folder && otherFolder.hasAttribute("data-open")) {
              setOpen(otherFolder, false);
            }
          }
          setOpen(folder, !folder.hasAttribute("data-open"));
        });
      }
    }

    setRootState(root);
  }
</script>
