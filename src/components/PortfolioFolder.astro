---
import "../styles/portfolio-folder.css";
import MusicPlayer from "./MusicPlayer.astro";
import type { Track } from "./music-player/types";

interface Props {
  panelId: string;
  title: string;
  description: string;
  longDescription: string;
  tracks: Track[];
}

const { panelId, title, description, longDescription, tracks } = Astro.props;
---

<div class="retro-folder group font-mono" data-folder>
  <button class="folder-tab-shell" type="button" data-folder-toggle aria-expanded="false" aria-controls={panelId}>
    <span class="folder-tab">
      <strong class="folder-tab-title">{title}</strong>
    </span>
  </button>

  <div class="folder-view">
    <button class="folder-face" type="button" data-folder-toggle aria-expanded="false" aria-controls={panelId}>
      <span class="folder-face-copy">
        <span class="folder-description-teaser">{description}</span>
        <span class="folder-description-full">{description}</span>
      </span>
      <span class="folder-chevron" aria-hidden="true"></span>
    </button>

    <div class="folder-body" id={panelId}>
      <div class="folder-detail-panel">
        <p class="body-copy mb-3 text-[#5b4021]">{longDescription}</p>
        <MusicPlayer tracks={tracks} />
      </div>
    </div>
  </div>
</div>
