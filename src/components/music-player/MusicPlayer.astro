---
import "../../styles/music-player.css";
import EqualizerPanel from "./EqualizerPanel.astro";
import TitleBar from "./TitleBar.astro";
import TrackList from "./TrackList.astro";
import VisualizerPanel from "./VisualizerPanel.astro";
import type { Track } from "./types";

interface Props {
  tracks: Track[];
}

const { tracks } = Astro.props as Props;
const hasTracks = tracks.length > 0;
---

<section class="music-player" data-music-player>
  <div class="music-player-shell">
    <TitleBar label="MUSIC PLAYER" />

    <div class="music-player-top">
      <div class="music-player-main-window">
        <div class="music-player-monitor-grid">
          <VisualizerPanel />

          <div class="music-player-readout-panel">
            <div class="music-player-trackline">
              <div class="music-player-trackline-viewport">
                <div class="music-player-trackline-marquee" data-player-marquee>
                  <span class="music-player-trackline-title" data-player-title>
                    {hasTracks ? tracks[0].title : "No tracks loaded"}
                  </span>
                  <span class="music-player-trackline-gap" aria-hidden="true"> ••• </span>
                  <span class="music-player-trackline-title-clone" data-player-title-clone aria-hidden="true">
                    {hasTracks ? tracks[0].title : "No tracks loaded"}
                  </span>
                </div>
              </div>
            </div>

            <div class="music-player-progress-shell">
              <input
                class="music-player-progress"
                type="range"
                min="0"
                max="100"
                value="0"
                step="0.1"
                data-player-progress
                disabled={!hasTracks}
                aria-label="Seek playback position"
              />
              <div class="music-player-time">
                <span data-player-current>0:00</span>
                <span data-player-duration>--:--</span>
              </div>
            </div>
          </div>
        </div>

        <div class="music-player-controls-row">
          <div class="music-player-controls">
            <button class="music-player-control" type="button" data-player-prev disabled={!hasTracks} aria-label="Previous track">
              <svg viewBox="0 0 16 16" aria-hidden="true">
                <path d="M.5 3.5A.5.5 0 0 0 0 4v8a.5.5 0 0 0 1 0V8.753l6.267 3.636c.54.313 1.233-.066 1.233-.697v-2.94l6.267 3.636c.54.314 1.233-.065 1.233-.696V4.308c0-.63-.693-1.01-1.233-.696L8.5 7.248v-2.94c0-.63-.692-1.01-1.233-.696L1 7.248V4a.5.5 0 0 0-.5-.5"/>
              </svg>
            </button>
            <button class="music-player-control music-player-control-primary" type="button" data-player-toggle disabled={!hasTracks} aria-label="Play">
              <svg class="music-player-icon-play" viewBox="0 0 16 16" aria-hidden="true">
                <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393"/>
              </svg>
              <svg class="music-player-icon-pause" viewBox="0 0 16 16" aria-hidden="true">
                <path d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5m5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5"/>
              </svg>
            </button>
            <button class="music-player-control" type="button" data-player-next disabled={!hasTracks} aria-label="Next track">
              <svg viewBox="0 0 16 16" aria-hidden="true">
                <path d="M15.5 3.5a.5.5 0 0 1 .5.5v8a.5.5 0 0 1-1 0V8.753l-6.267 3.636c-.54.313-1.233-.066-1.233-.697v-2.94l-6.267 3.636C.693 12.703 0 12.324 0 11.693V4.308c0-.63.693-1.01 1.233-.696L7.5 7.248v-2.94c0-.63.693-1.01 1.233-.696L15 7.248V4a.5.5 0 0 1 .5-.5"/>
              </svg>
            </button>
          </div>
        </div>

        <EqualizerPanel />
      </div>

      <TrackList tracks={tracks} />
    </div>
  </div>

  <audio data-player-audio preload="none"></audio>
</section>

<script>
  import { setupMusicPlayers } from "./player-client";

  setupMusicPlayers();
</script>
